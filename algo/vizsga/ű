class Node():
    def __init__(self, data):
        self.data = data
        self.next = None

    def __str__(self):
        return str(self.data)


class LinkedList():
    def __init__(self):
        self.head = None
        self.tail = None
        self.counter = 0
        self.error = False

    def printList(self):
        tmp = self.head
        while tmp:
            print(tmp, end=" ")
            tmp = tmp.next
            if tmp:
                print("-->", end=" ")

        print()

    def insertAtBeggining(self, data):
        new_Node = Node(data)
        new_Node.next = self.head
        self.head = new_Node
        if self.tail == None:
            self.tail = self.head
        self.counter +=1

    def removeFromBeggining(self,data):
        if self.head == None:
            self.error = True

        else:
            self.head = self.head.next




